#!/usr/bin/env sh
# Refresh ai-input after each commit.
# This hook is intentionally small and optional.
# Set AI_WORKFLOW_SKIP_HOOKS=1 to skip all automation.

if [ "${AI_WORKFLOW_SKIP_HOOKS}" = "1" ]; then
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh ./scripts/refresh-ai-input.ps1 -GenerateLastCommitBundle || true
fi

exit 0
