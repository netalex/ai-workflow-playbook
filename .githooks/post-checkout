#!/usr/bin/env sh
# Refresh ai-input after branch checkout or file restore.
# This keeps the staged context aligned with the current branch.

if [ "${AI_WORKFLOW_SKIP_HOOKS}" = "1" ]; then
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh ./scripts/refresh-ai-input.ps1 || true
fi

exit 0
